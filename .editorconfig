root = true

[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true
indent_style             = space
indent_size              = 4

[*.{md,yaml,yml,json}]
indent_size = 2

[Makefile]
indent_style = tab

# Vendored sources keep their upstream formatting.
[third_party/**]
indent_style             = unset
indent_size              = unset
trim_trailing_whitespace = false
insert_final_newline     = false
